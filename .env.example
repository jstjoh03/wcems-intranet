# ───────────────────────────────────────────────────────────────────
# Vite (browser-bundled) env — Vue app reads these via import.meta.env
# ───────────────────────────────────────────────────────────────────

# Supabase ──────────────────────────────────────────────────────────
# Project URL + publishable key from the Supabase dashboard
# (Settings → API). The publishable key is safe to expose to the
# browser — RLS gates row access.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=


# ───────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets (NOT bundled into the browser)
#
# Set these via the CLI, not via this file:
#   npx supabase secrets set NAME="value"
#
# The `sync-wix-training` Edge Function reads them at runtime to pull
# upcoming training from Wix Bookings AND the Internal Education
# group calendar (Microsoft Graph), upserting into `training_sessions`
# every 15 minutes via pg_cron.
# ───────────────────────────────────────────────────────────────────

# Wix Bookings ─────────────────────────────────────────────────────
# WIX_API_TOKEN=IST.eyJraWQ...   # IST token from Wix dashboard
# WIX_SITE_ID=36355ce1-011b-411e-9d37-6c6818a9081e

# Microsoft Graph (Education group calendar — "blue" tagged events) ─
# Same Entra app registration used for Supabase OAuth. Required:
#   • Application permission `Calendars.Read` (or Group.Read.All).
#     Admin consent granted for the tenant.
#   • A client secret generated under Certificates & secrets →
#     Client secrets → New client secret. Copy the VALUE (only shown
#     once); the secret_id is not what you want.
#
# GRAPH_TENANT_ID=08b5bff4-54a4-41b1-8dc9-33f4dc1a0127
# GRAPH_CLIENT_ID=86d0e431-6005-436e-b2a4-7cc76d6b0788
# GRAPH_CLIENT_SECRET=<from Entra → Certificates & secrets>
# GRAPH_GROUP_ID=60fb203c-dce7-490b-a1f3-0dcdd5d8c6b3
